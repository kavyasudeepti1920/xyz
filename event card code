#include <stdio.h>

struct Student
{
    int id;
    char name[30];
    float marks;
    char address[100];
};

int main()
{
    struct Student s[3];
    int i;
    float total = 0, avg;
    int highest = 0;

    printf("Enter details of 3 students:\n");

    for(i = 0; i < 4; i++)
    {
        printf("\nStudent %d\n", i + 1);

        printf("Enter ID: ");
        scanf("%d", &s[i].id);

        printf("Enter Name: ");
        scanf("%s", s[i].name);

        printf("Enter Marks: ");
        scanf("%f", &s[i].marks);

        total += s[i].marks;

        if(s[i].marks > s[highest].marks)
        {
            highest = i;
        }
    }

    avg = total / 3;

    printf("\n----- Student Details -----\n");

    for(i = 0; i < 3; i++)
    {
        printf("ID: %d\n", s[i].id);
        printf("Name: %s\n", s[i].name);
        printf("Marks: %.2f\n\n", s[i].marks);
    }

    printf("Average Marks = %.2f\n", avg);

    printf("\nTop Student:\n");
    printf("ID: %d\n", s[highest].id);
    printf("Name: %s\n", s[highest].name);
    printf("Marks: %.2f\n", s[highest].marks);

    return 0;
}
